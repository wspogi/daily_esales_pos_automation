# ============================================================
# DAILY E-SALES POS AUTOMATION - ENV CONFIG
# ============================================================
# Purpose:
#   Dito nakalagay lahat ng settings ng automation.
#   Per branch, ito lang usually ang babaguhin:
#   - SQL connection
#   - POS branch/header details
#   - Date mode
# ============================================================


# ============================================================
# SQL SERVER CONNECTION
# ============================================================

# SQL Server IP address or hostname ng POS database.
# Example:
# SQL_SERVER=192.168.1.3
SQL_SERVER=192.168.1.3

# POS database name.
# Example:
# SQL_DATABASE=VQPBOS
SQL_DATABASE=VQPBOS

# SQL username.
SQL_USERNAME=your_username

# SQL password.
SQL_PASSWORD=your_password

# ODBC Driver installed sa PC.
# Common values:
# SQL_DRIVER=ODBC Driver 17 for SQL Server
# SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_DRIVER=ODBC Driver 17 for SQL Server

# Encryption setting.
# Usually "no" for local POS SQL Server using ODBC Driver 17.
# For ODBC Driver 18, minsan kailangan "yes".
SQL_ENCRYPT=no

# Trust SQL Server certificate.
# Recommended "yes" para iwas SSL/certificate issue.
SQL_TRUST_SERVER_CERTIFICATE=yes


# ============================================================
# POS BRANCH / REPORT HEADER INFO
# ============================================================

# Branch code / terminal identifier.
# Example: CAM, DAET, NAGA, etc.
POS_BRANCH=CAM

# Company name na lalabas sa Excel header row 1.
POS_COMPANY_NAME=STA. MARIA CONSTRUCTION

# Operator name na lalabas sa Excel header row 2.
POS_OPERATOR_NAME=operated by: JHON MOISES R BRIAGAS

# Static BIR/POS details from POS permit/template.
# Iwan blank kung wala or hindi applicable.
POS_TIN=

# POS machine serial number.
POS_SERIAL_NO=0712202402086

# Machine Identification Number.
POS_MIN=24080816245370261

# Permit number.
POS_PERMIT_NO=FP082024-067-0461594-00000


# ============================================================
# DATE SETTINGS
# ============================================================

# Options:
# PREVIOUS_MONTH = automatic previous month
# CURRENT_MONTH  = automatic current month
# CUSTOM         = use DATE_FROM and DATE_TO below
DATE_MODE=PREVIOUS_MONTH

# Required only when DATE_MODE=CUSTOM.
# Format: YYYY-MM-DD
DATE_FROM=2026-04-01
DATE_TO=2026-04-30


# ============================================================
# VAT ROUNDING SETTINGS
# ============================================================

# Options:
# PER_TRANSACTION = vatable is rounded per receipt then summed
# SUMMARY         = vatable is computed from total Net Sales / 1.12
VAT_ROUNDING_MODE=PER_TRANSACTION


# ============================================================
# OUTPUT SETTINGS
# ============================================================

# Folder kung saan ilalagay ang generated Excel file.
OUTPUT_DIR=output

# Folder kung saan ilalagay ang log files.
LOG_DIR=logs